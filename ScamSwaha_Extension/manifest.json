{
  "manifest_version": 3,
  "name": "ScamSwaha WhatsApp Interceptor",
  "version": "1.0",
  "description": "Live real-time scam detection for WhatsApp Web.",
  "permissions": ["activeTab"],
  "host_permissions": [
    "https://*/*",
    "http://127.0.0.1:5000/*",
    "http://localhost:5000/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://web.whatsapp.com/*"],
      "js": ["content.js"]
    }
  ]
}